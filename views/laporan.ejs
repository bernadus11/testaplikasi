<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Laporan Kelas <%= kelas %> - SD Kanisius Kaliwinong</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f5f5f5;
        }
        .header {
            background-color: #13635e;
            color: white;
            padding: 20px;
            text-align: center;
        }
        .container {
            margin-top: 30px;
        }
        .table th {
            background-color: #198754;
            color: white;
        }
        .btn-back {
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>📋 Laporan Absensi</h1>
        <h4>SD Kanisius Kaliwinong - Kelas <%= kelas %></h4>
    </div>

    <div class="container">
        <a href="/kelas1" class="btn btn-secondary btn-back">← Kembali ke Dashboard</a>
        <div class="table-responsive">
            <table class="table table-bordered table-hover">
                <thead>
                    <tr>
                        <th>No Absen</th>
                        <th>Nama</th>
                        <th>Kelas</th>
                        <th>Tanggal</th>
                        <th>Keterangan</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (laporan.length === 0) { %>
                        <tr><td colspan="5" class="text-center">Tidak ada data absensi.</td></tr>
                    <% } else { %>
                        <% laporan.forEach((data) => { %>
                            <tr>
                                <td><%= data.id %></td>
                                <td><%= data.nama %></td>
                                <td><%= data.kelas %></td>
                                <td><%= new Date(data.created_at).toLocaleDateString('id-ID') %></td>
                                <td><%= data.keterangan %></td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
        <form action="/download-excel" method="GET">
            <label for="kelas">Pilih Kelas:</label>
            <select name="kelas" id="kelas">
                <% for (let i = 1; i <= 6; i++) { %>
                    <option value="<%= i %>">Kelas <%= i %></option>
                <% } %>
            </select>
            <button type="submit" class="btn btn-success">📥 Download Excel</button>
        </form>
    </div>
</body>
</html>
